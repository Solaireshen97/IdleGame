@using Game.Shared.Dtos.Auth

<article class="character-card @(IsCurrent ? "character-card--current" : string.Empty)">
    <div class="character-card__header">
        <h3 class="character-card__name">@Character.Name</h3>
        <div class="character-card__header-actions">
            @if (IsCurrent)
            {
                <span class="character-card__badge">当前角色</span>
            }
            else
            {
                <button type="button"
                        class="character-card__select"
                        @onclick="OnSelect"
                        disabled="@IsInteractionDisabled"
                        title="@SelectDisabledReason">
                    @SelectButtonText
                </button>
            }
            <button type="button"
                    class="character-card__delete"
                    @onclick="OnDelete"
                    disabled="@(!CanDelete || IsInteractionDisabled)"
                    title="@DeleteDisabledReason">
                @DeleteButtonText
            </button>
        </div>
    </div>

    <dl class="character-card__stats">
        <div>
            <dt>HP</dt>
            <dd>@Character.Hp / @Character.MaxHp</dd>
        </div>
        <div>
            <dt>Attack</dt>
            <dd>@Character.Attack</dd>
        </div>
        <div>
            <dt>Defense</dt>
            <dd>@Character.Defense</dd>
        </div>
    </dl>
</article>

@code {
    [Parameter, EditorRequired]
    public CharacterSummaryResponse Character { get; set; } = default!;

    [Parameter]
    public bool IsCurrent { get; set; }

    [Parameter]
    public bool CanDelete { get; set; } = true;

    [Parameter]
    public bool IsInteractionDisabled { get; set; }

    [Parameter]
    public bool IsDeleting { get; set; }

    [Parameter]
    public bool IsSelecting { get; set; }

    [Parameter]
    public string? SelectDisabledReason { get; set; }

    [Parameter]
    public string? DeleteDisabledReason { get; set; }

    [Parameter]
    public EventCallback OnSelect { get; set; }

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private string SelectButtonText => IsSelecting ? "切换中..." : "设为当前";

    private string DeleteButtonText => IsDeleting
        ? "删除中..."
        : CanDelete
            ? "删除"
            : "不可删除";
}
