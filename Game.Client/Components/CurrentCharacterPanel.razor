@using Game.Client.Services
@using Game.Shared.Dtos.Auth
@inject ApiService ApiService

@if (!_isLoading && _characters.Count > 0)
{
    @for (var index = 0; index < _characters.Count; index++)
    {
        <CharacterCard Character="_characters[index]" IsCurrent="@(index == 0)" />
    }
}
else if (!_isLoading && _showEmptyState)
{
    <p class="current-character-panel__empty">当前账号暂无角色。</p>
}

@code {
    private List<CharacterSummaryResponse> _characters = [];
    private bool _isLoading = true;
    private bool _showEmptyState;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var characters = await ApiService.GetCurrentCharactersAsync();
            if (characters is not null)
            {
                _characters = characters;
                _showEmptyState = _characters.Count == 0;
            }
        }
        catch
        {
            _characters = [];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
