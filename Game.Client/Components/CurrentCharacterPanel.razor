@using Game.Client.Services
@using Game.Shared.Dtos.Auth
@inject ApiService ApiService

@if (!_isLoading && _character is not null)
{
    <section class="current-character-card">
        <h3 class="current-character-card__title">当前角色</h3>
        <p class="current-character-card__name">@_character.Name</p>
        <dl class="current-character-card__stats">
            <div>
                <dt>HP</dt>
                <dd>@_character.Hp / @_character.MaxHp</dd>
            </div>
            <div>
                <dt>Attack</dt>
                <dd>@_character.Attack</dd>
            </div>
            <div>
                <dt>Defense</dt>
                <dd>@_character.Defense</dd>
            </div>
        </dl>
    </section>
}

@code {
    private CurrentCharacterResponse? _character;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _character = await ApiService.GetCurrentCharacterAsync();
        }
        catch
        {
        }
        finally
        {
            _isLoading = false;
        }
    }
}
