@page "/battle/{roomId:int}"
@using Game.Client.Services
@using Game.Shared.Dtos
@inject ApiService ApiService
@inject NavigationManager Navigation

<PageTitle>房间</PageTitle>

<h1>IdleGame V0.5 — 房间</h1>

<button @onclick="GoToRooms">← 返回房间列表</button>

@if (_roomDetail is null)
{
    <p>Loading room...</p>
}
else if (!_roomDetail.HasPlayer)
{
    <h2>房间 #@_roomDetail.RoomId</h2>
    <p><strong>怪物：</strong> @_roomDetail.MonsterName (@_roomDetail.MonsterHp / @_roomDetail.MonsterMaxHp HP)</p>
    <p><em>当前还没有玩家加入战斗。</em></p>
    <button @onclick="JoinRoomAsync" disabled="@_isBusy">加入战斗</button>

    @if (_message is not null)
    {
        <p><em>@_message</em></p>
    }
}
else
{
    <p><strong>Player:</strong> @_roomDetail.PlayerName</p>
    <p><strong>Character:</strong> @_roomDetail.CharacterName (@_roomDetail.CharacterHp / @_roomDetail.CharacterMaxHp HP)</p>
    <p><strong>Monster:</strong> @_roomDetail.MonsterName (@_roomDetail.MonsterHp / @_roomDetail.MonsterMaxHp HP)</p>
    <p><strong>Room Status:</strong> @_roomDetail.RoomStatus</p>

    @if (_roomDetail.IsCurrentPlayerOwner)
    {
        <p><em>你是房主</em></p>
    }

    <button @onclick="StartBattleAsync" disabled="@_isBusy">开始战斗</button>
    <button @onclick="ResetBattleAsync" disabled="@_isBusy">重置战斗</button>
    <button @onclick="HealAsync" disabled="@_isBusy">恢复10HP</button>

    @if (_roomDetail.IsCurrentPlayerOwner)
    {
        <button @onclick="DismissRoomAsync" disabled="@_isBusy" style="margin-left: 1em; color: red;">解散房间</button>
    }

    <h3>战斗日志</h3>
    @if (_logs.Count == 0)
    {
        <p>暂无日志</p>
    }
    else
    {
        <ul>
            @foreach (var log in _logs)
            {
                <li>@log</li>
            }
        </ul>
    }

    @if (_message is not null)
    {
        <p><em>@_message</em></p>
    }
}

@code {
    [Parameter]
    public int RoomId { get; set; }

    private RoomDetailResponse? _roomDetail;
    private readonly List<string> _logs = new();
    private bool _isBusy;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await RefreshRoomDetailAsync();
    }

    private async Task JoinRoomAsync()
    {
        _isBusy = true;
        _message = null;
        var detail = await ApiService.JoinRoomAsync(RoomId);
        if (detail is null)
        {
            _message = "加入战斗失败（房间可能已有成员或不存在）。";
        }
        else
        {
            _roomDetail = detail;
        }
        _isBusy = false;
    }

    private async Task StartBattleAsync()
    {
        _isBusy = true;
        var result = await ApiService.StartBattleAsync(RoomId);
        _logs.Clear();

        if (result is null)
        {
            _logs.Add("Battle request failed.");
        }
        else
        {
            _logs.AddRange(result.Logs);
        }

        await RefreshRoomDetailAsync();
        _isBusy = false;
    }

    private async Task ResetBattleAsync()
    {
        _isBusy = true;
        var roomDetail = await ApiService.ResetBattleAsync(RoomId);
        _logs.Clear();

        if (roomDetail is null)
        {
            _logs.Add("Reset request failed.");
        }
        else
        {
            _roomDetail = roomDetail;
            _logs.Add("Battle reset.");
        }

        _isBusy = false;
    }

    private async Task HealAsync()
    {
        _isBusy = true;
        var roomDetail = await ApiService.HealAsync(RoomId);
        _logs.Clear();

        if (roomDetail is null)
        {
            _logs.Add("Heal request failed.");
        }
        else
        {
            _roomDetail = roomDetail;
            _logs.Add("Recovered 10 HP.");
        }

        _isBusy = false;
    }

    private async Task DismissRoomAsync()
    {
        _isBusy = true;
        _message = null;
        var success = await ApiService.DeleteRoomAsync(RoomId);
        if (!success)
        {
            _message = "解散房间失败。";
            _isBusy = false;
        }
        else
        {
            Navigation.NavigateTo("/rooms");
        }
    }

    private async Task RefreshRoomDetailAsync()
    {
        _roomDetail = await ApiService.GetRoomDetailAsync(RoomId);
    }

    private void GoToRooms()
    {
        Navigation.NavigateTo("/rooms");
    }
}
